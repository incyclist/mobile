    "react-native-screens": "^4.23.0",
    "react-native-svg": "^15.15.3",
    "react-native-tcp-socket": "^6.4.1",
    "react-native-zeroconf": "^0.14.0",
    "react-native-zip-archive": "^7.0.2",
