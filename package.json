{
  "name": "incyclist",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "clean:android": "./scripts/clean.sh",
    "release:android": "./scripts/build-release-android.sh",
    "dev:android": "APP_VARIANT=dev   react-native run-android --mode dev",
    "debug:android": "APP_VARIANT=debug  react-native run-android --mode debug",
    "ios": "react-native run-ios",
    "lint": "eslint .",
    "start": "react-native start --reset-cache",
    "test": "jest",
    "bundle:android": "react-native bundle --platform android --dev false --entry-file index.js --bundle-output ~/dist/index.android.bundle --assets-dest ~/dist"
  },
  "dependencies": {
    "@react-native/new-app-screen": "0.83.1",
    "buffer": "^6.0.3",
    "events": "^3.3.0",
    "gd-eventlog": "^0.1.27",
    "incyclist-services": "^1.7.11",
    "process": "^0.11.10",
    "react": "19.2.0",
    "react-native": "0.83.1",
    "react-native-bootsplash": "^7.0.1",
    "react-native-config": "^1.6.1",
    "react-native-default-preference": "^1.4.4",
    "react-native-fs": "^2.20.0",
    "react-native-get-random-values": "^2.0.0",
    "react-native-orientation-locker": "^1.7.0",
    "react-native-safe-area-context": "^5.6.2",
    "react-native-zip-archive": "^7.0.2"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/plugin-transform-class-static-block": "^7.28.6",
    "@babel/plugin-transform-export-namespace-from": "^7.27.1",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@bam.tech/react-native-make": "^3.0.3",
    "@react-native-community/cli": "20.0.0",
    "@react-native-community/cli-platform-android": "20.0.0",
    "@react-native-community/cli-platform-ios": "20.0.0",
    "@react-native/babel-preset": "0.83.1",
    "@react-native/eslint-config": "0.83.1",
    "@react-native/metro-config": "0.83.1",
    "@react-native/typescript-config": "0.83.1",
    "@serialport/binding-mock": "^10.2.2",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.2.0",
    "@types/react-test-renderer": "^19.1.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "prettier": "2.8.8",
    "react-test-renderer": "19.2.0",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20"
  }
}
