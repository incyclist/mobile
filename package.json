    "gd-eventlog": "^0.1.27",
    "i": "^0.3.7",
    "incyclist-services": "^1.7.14",
    "process": "^0.11.10",
    "react": "^19.2.4",
    "react-native": "0.83.1",
    "react-native-ble-manager": "^12.4.4",
