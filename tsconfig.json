{
  "extends": "@react-native/typescript-config",
  "compilerOptions": {
    "baseUrl": ".",
    "jsx": "react-native", 
    // OR "jsx": "react-jsx" for the modern transform
    "allowJs": true,
    "esModuleInterop": true,
    "types": ["jest"],
    "paths": {
      "@assets/*": ["src/assets/*"],
      "@settings": ["polyfill/settings.ts"]
    }    
  },
  "include": ["**/*.ts", "**/*.tsx", "src/types/**/*.d.ts"],
  "exclude": ["**/node_modules", "**/Pods", "**/internal" ]
}
